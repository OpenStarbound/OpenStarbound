{
  "frameBuffers" : {
    "main" : {
      "hdr":"FromSetting",
      // "main" is the ONLY framebuffer that may be multisampled: it is MSAA-resolved to the default
      // framebuffer with glBlitFramebuffer (a legal MSAA resolve) and is never bound to a sampler.
      // Any framebuffer a shader SAMPLES must leave this off -- a GL_TEXTURE_2D_MULTISAMPLE texture
      // cannot be bound as GL_TEXTURE_2D, and the failed bind is silent.
      "allowMultisample":true
    }
  }
}
